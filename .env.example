# ----------------------------------------------------------------------------
# Shehryar MVP Platform — environment variables
# Copy to `.env.local` for local dev and fill in the values.
# NEVER commit the real .env.local file.
# ----------------------------------------------------------------------------

# --- Supabase (Project Settings → API) --------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI providers -----------------------------------------------------------
# Anthropic (primary content engine). https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-xxxxxxxx
# Default model. Options: claude-opus-4-8 (best), claude-sonnet-4-6 (cheaper,
# great for high-volume drafting), claude-haiku-4-5 (fastest/cheapest).
CLAUDE_MODEL=claude-opus-4-8

# OpenAI (optional — used by the Image Agent for DALL·E renders).
OPENAI_API_KEY=sk-xxxxxxxx

# Azure OpenAI (optional alternative to OpenAI).
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# --- GitHub (optional) ------------------------------------------------------
# Personal access token with contents:write on the target repo. Lets the
# PowerShell Script Agent push generated scripts to GitHub.
GITHUB_TOKEN=
# Target repo in "owner/repo" form, e.g. sherryberry001/m365-scripts
GITHUB_REPO=

# --- App ---------------------------------------------------------------------
# Public site URL — used for SEO canonical URLs, sitemap, RSS, OG images.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Shared secret required to trigger automation endpoints / cron jobs.
AUTOMATION_SECRET=change-me-to-a-long-random-string

# Owner identity (shown across the site).
NEXT_PUBLIC_OWNER_NAME="Shehryar Hassan"
NEXT_PUBLIC_OWNER_EMAIL=Shehryar.hassan@dizparc.se
